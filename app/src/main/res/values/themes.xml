<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme — DarkActionBar for MainActivity + exercise fragments -->
    <style name="Theme.AndroidInterviewExercises" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#4A90E2</item>
        <item name="colorPrimaryVariant">#2C6FBF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#F5A623</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!--
        Shopping Activity theme — MUST use NoActionBar.

        The crash "This Activity already has an action bar supplied by the window decor"
        happens because DarkActionBar provides a system action bar AND ShoppingActivity
        calls setSupportActionBar(toolbar) to set its own Toolbar.
        Android disallows two action bars in the same window.

        Fix: use a NoActionBar parent so the window decor provides NO action bar,
        and our custom Toolbar in activity_shopping.xml becomes the sole action bar.
        setSupportActionBar() then works correctly.

        Interview note: Any Activity that manages its own Toolbar must use a
        NoActionBar theme variant. This is a very common crash seen in code reviews.
    -->
    <style name="Theme.AndroidInterviewExercises.Shopping" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4A90E2</item>
        <item name="colorPrimaryVariant">#2C6FBF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#F5A623</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

</resources>
