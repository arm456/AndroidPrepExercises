<?xml version="1.0" encoding="utf-8"?>
<!--
    item_bet_option.xml

    Bug fix: CardView was intercepting all touch events before they reached
    the Button child. This is because CardView sets clickable=true by default
    when cardElevation > 0 (it creates a StateListAnimator that consumes touches).

    Fix: explicitly set clickable=false and focusable=false on the CardView so
    touch events fall through to the child Button.

    Interview note: This is a common gotcha with CardView + Button combinations.
    The same issue can happen with any ViewGroup that has a ripple/state animator
    (ConstraintLayout with background, etc.). Always check parent clickable state
    when a child's click listener isn't firing.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:clickable="false"
    android:focusable="false"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#16213E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="false"
        android:focusable="false">

        <TextView
            android:id="@+id/tvBetLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvBetAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:textSize="14sp"
            android:textColor="#F5A623"
            android:minWidth="40dp"
            android:gravity="end"/>

        <Button
            android:id="@+id/btnIncrementBet"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="+$1"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"
            android:backgroundTint="#4A90E2"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
