<?xml version="1.0" encoding="utf-8"?>
<!--
    Roll result row — shows the number rolled and earnings.
    Earnings text is colored green (win) or red (loss) in HistoryAdapter.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#16213E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Roll number, e.g. "Rolled: 17" -->
        <TextView
            android:id="@+id/tvRollNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="#FFFFFF"/>

        <!-- Earnings, e.g. "+$4" or "-$2" — color set programmatically -->
        <TextView
            android:id="@+id/tvEarnings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:minWidth="60dp"
            android:gravity="end"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
