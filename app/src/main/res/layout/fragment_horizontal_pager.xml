<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for Approach B: ViewPager2 (snap, one-at-a-time).

    Structure:
      [Header] — updates on onPageSelected()
      [ViewPager2] — snap scroll, one page at a time
      [Page indicator] — "2 / 7"
      [Footer] — updates on onPageSelected()

    Key difference from RecyclerView approach: each "item" here is a full
    Fragment (ExercisePageFragment), not just a ViewHolder. The outer Fragment
    (this layout's host) owns the header and footer.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- HEADER: updated by HorizontalPagerFragment via ViewModel observation -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:text="📂  Loading..."/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="APPROACH B — ViewPager2 (snap)"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:letterSpacing="0.1"/>

        <!-- ViewPager2: enforces one-page-at-a-time snapping automatically -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPagerHorizontal"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"/>

        <!-- Page indicator — e.g. "2 / 7" -->
        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:text="1 / 7"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:text="Swipe one at a time. Header/footer update on snap."
            android:textSize="12sp"
            android:textColor="#6B7280"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB"/>

    <!-- FOOTER: updated via ViewModel observation -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:textSize="14sp"
        android:textColor="#4B5563"
        android:background="#FFFFFF"
        android:text="Swipe to see description..."/>

</LinearLayout>
