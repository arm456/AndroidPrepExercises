<?xml version="1.0" encoding="utf-8"?>
<!--
    HistoryFragment layout.
    Milestone 1: shows roll results with number + earnings.
    Milestone 2: updates automatically via LiveData — no pull-to-refresh needed.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Roll History"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#16213E"
        android:elevation="4dp"/>

    <!-- Swipe hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Swipe left to bet →"
        android:textSize="11sp"
        android:textColor="#6B7280"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmptyHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp"
        android:text="No rolls yet. Place a bet and spin!"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:visibility="visible"/>

    <!-- History list — updates automatically via LiveData -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>
