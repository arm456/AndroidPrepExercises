<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for Approach A: RecyclerView horizontal scroll.

    Structure:
      [Header] — shows the currently centered item's title
      [RecyclerView] — horizontal, scrollable, no snapping
      [Footer] — shows the currently centered item's description

    The header and footer are updated by observing ViewModel LiveData in
    HorizontalListFragment — they don't scroll with the list.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- HEADER: updates to match the centered card -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:text="📂  Loading..."/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB"/>

    <!-- Centered vertically between header and footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="APPROACH A — RecyclerView (multi-scroll)"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:letterSpacing="0.1"/>

        <!-- The horizontal RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewHorizontal"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:overScrollMode="never"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:text="Scroll freely. Header/footer update on scroll stop."
            android:textSize="12sp"
            android:textColor="#6B7280"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB"/>

    <!-- FOOTER: updates to match the centered card -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:textSize="14sp"
        android:textColor="#4B5563"
        android:background="#FFFFFF"
        android:text="Scroll to see description..."/>

</LinearLayout>
