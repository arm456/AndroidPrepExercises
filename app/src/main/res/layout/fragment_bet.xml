<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Money display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#16213E">

        <TextView
            android:id="@+id/tvTotalMoney"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Balance: $100"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F5A623"/>

        <TextView
            android:id="@+id/tvTotalBet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Bet: $0"
            android:textSize="14sp"
            android:textColor="#9CA3AF"/>

    </LinearLayout>

    <!-- Swipe hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="← Swipe right for history"
        android:textSize="11sp"
        android:textColor="#6B7280"
        android:gravity="end"/>

    <!-- Bet options list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewBets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Action buttons — no android:gap; use layout_marginStart on second button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#16213E">

        <Button
            android:id="@+id/btnClearBets"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clear Bets"
            android:backgroundTint="#374151"/>

        <Button
            android:id="@+id/btnRoll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="12dp"
            android:text="ROLL"
            android:textSize="16sp"
            android:backgroundTint="#F5A623"/>

    </LinearLayout>

</LinearLayout>
