<?xml version="1.0" encoding="utf-8"?>
<!--
    HomeFragment layout.

    The "Go to Cart" button at the bottom is the Milestone 2 addition —
    a third entry point to CartFragment alongside bottom nav and drawer.

    Using a plain Button (not FAB) to avoid the FloatingActionButton
    cast issue when the view is found as android.widget.Button in code.
    The navigation concept is identical regardless of button style.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Product list fills available space -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- ── Milestone 2: Extra cart entry point ─────────────────────────── -->
    <!--
        Designer requested a shortcut button on the home screen so the user
        can jump to cart without using bottom nav or drawer.
        This is the third navigation path added in Milestone 2.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#16213E"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#9CA3AF"
            android:text="Items in cart:"/>

        <TextView
            android:id="@+id/tvCartBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F5A623"
            android:text="0"/>

        <Button
            android:id="@+id/btnGoToCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View Cart →"
            android:textSize="13sp"
            android:backgroundTint="#F5A623"/>

    </LinearLayout>

</LinearLayout>
